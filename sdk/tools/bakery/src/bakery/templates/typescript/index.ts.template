// $name — TypeScript inferlet.
//
// Demonstrates:
// - Using Context for chat-style prompt building
// - Returning the generated response to the caller

import {
    Context, Sampler,
    session,
} from '@pie-project/inferlet';

interface Input {
    prompt?: string;
    system?: string;
    max_tokens?: number;
    temperature?: number;
    top_p?: number;
}

export async function main(input: Input) {
    const prompt = input.prompt ?? 'What is the capital of France?';
    const system = input.system ?? 'You are a helpful, respectful and honest assistant.';
    const maxTokens = input.max_tokens ?? 256;
    const temperature = input.temperature ?? 0.6;
    const topP = input.top_p ?? 0.95;

    // Build a chat context.
    const ctx = new Context();
    ctx.system(system);
    ctx.user(prompt);

    const output = await ctx
        .generate(Sampler.topP(temperature, topP), { maxTokens })
        .collectText();

    session.send(output);
    return output;
}
