interface adapter {
    use types.{error};
    
    resource adapter {

        create: static func(name:string) -> result<adapter, error>;

        destroy: func();

        open: static func(name:string) -> option<adapter>;

        fork: func(name:string) -> adapter;

        load: func(path:string) -> result<_, error>;

        save: func(path:string) -> result<_, error>;

    }


}