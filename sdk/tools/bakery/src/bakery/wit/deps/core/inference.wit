interface inference {
    use types.{error};
    use context.{context};
    use adapter.{adapter};
    use model.{tokenizer};
    use media.{image, audio};
    use tensor.{tensor, program};

    type brle = list<u32>;

    variant input-binding {
        /// Forward-pass output positions whose logits are bound to this input.
        /// Shape `[vocab]` for one position, or `[len(positions), vocab]` for
        /// multiple. Multiple samplers may name overlapping positions; the
        /// runtime may coalesce the underlying logit computation.
        logits(list<u32>),
        tensor(tensor),
    }

    resource forward-pass {
        constructor();
        context: func(context: borrow<context>);
        input-tokens: func(tokens: list<u32>, positions: list<u32>);
        input-image: func(image: borrow<image>, anchor: u32);
        input-audio: func(audio: borrow<audio>, anchor: u32);
        attention-mask: func(mask: list<brle>);
        /// Attach one tensor program as the sampler. Binding `i` supplies the
        /// program input at index `i`. Result tensors follow the program's
        /// declared output order.
        sampler: func(program: borrow<program>, inputs: list<input-binding>);
        /// Attach multiple tensor programs as samplers. `inputs[i]` supplies the
        /// positional bindings for `programs[i]`. Output order mirrors `programs`.
        batch-sampler: func(programs: list<borrow<program>>, inputs: list<list<input-binding>>);
        adapter: func(adapter: borrow<adapter>);

        /// -- pipelining primitives ---------------------
        /// Feed an i32 token/id vector produced by a sampler into the next pass.
        /// Uses the first tensor output of the first sampler; lanes with the
        /// sentinel value `-1` are ignored.
        next-input: func(positions: list<u32>);
        next-attention-mask: func(mask: list<brle>);
        next-adapter: func(adapter: borrow<adapter>);

        /// Submit. Tensor inputs referenced by samplers must be ready before
        /// their first consuming compiled region executes.
        execute: func();
        /// Single-sampler output tensors (waits for completion). Follows the
        /// program's declared output order.
        output: func() -> result<list<tensor>, error>;
        /// Batch-sampler output tensors. Outer list follows `batch-sampler.programs`;
        /// each inner list follows that program's declared output order.
        outputs: func() -> result<list<list<tensor>>, error>;
    }

    /// Describes the structure that the LLM output must conform to.
    /// Constructed via static factory methods for each supported format.
    resource grammar {
        /// Construct from a JSON Schema string.
        from-json-schema: static func(schema: string) -> result<grammar, error>;

        /// Construct a built-in free-form JSON grammar (any valid JSON).
        json: static func() -> grammar;

        /// Construct from a regular expression pattern.
        from-regex: static func(pattern: string) -> result<grammar, error>;

        /// Construct from an EBNF grammar string.
        from-ebnf: static func(ebnf: string) -> result<grammar, error>;

        /// Debug representation of the grammar. Format is unspecified and
        /// may differ across grammar kinds; do not parse.
        to-string: func() -> string;
    }

    /// Stateful matcher that walks the grammar automaton as tokens are
    /// accepted, producing a bitmask of valid next tokens at each step.
    /// The host compiles the grammar on construction and may cache the
    /// compiled result internally.
    resource matcher {
        /// Create a new matcher from a grammar and tokenizer.
        constructor(grammar: borrow<grammar>, tokenizer: borrow<tokenizer>);

        /// Accept one or more decoded tokens, advancing the matcher state.
        /// Returns an error if any token violates the grammar.
        accept-tokens: func(token-ids: list<u32>) -> result<_, error>;

        /// Fill the next-token bitmask.  The returned BRLE encodes which
        /// token ids in the vocabulary are allowed at the current position.
        next-token-logit-mask: func() -> brle;

        /// Check whether the matcher has reached a terminal state.
        is-terminated: func() -> bool;

        /// Reset the matcher to its initial state so it can be reused.
        reset: func();
    }

}
