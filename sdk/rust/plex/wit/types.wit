interface types {
    record logical-request-id {
        high: u64,
        low: u64,
    }

    record delivery-id {
        high: u64,
        low: u64,
    }

    record fact-handle {
        value: u32,
    }

    record metadata-handle {
        value: u32,
    }

    record map-handle {
        value: u32,
    }

    record event-handle {
        value: u32,
    }

    record capability-handle {
        value: u32,
    }

    record link-set {
        facts: list<option<fact-handle>>,
        metadata: list<option<metadata-handle>>,
        maps: list<option<map-handle>>,
        events: list<option<event-handle>>,
        capabilities: list<option<capability-handle>>,
    }

    variant column-values {
        booleans(list<option<bool>>),
        signed64s(list<option<s64>>),
        unsigned64s(list<option<u64>>),
        float64s(list<option<f64>>),
        texts(list<option<string>>),
        byte-lists(list<option<list<u8>>>),
    }

    record fact-column {
        handle: fact-handle,
        values: column-values,
    }

    record metadata-column {
        handle: metadata-handle,
        values: column-values,
    }

    record record-batch {
        rows: u32,
        facts: list<fact-column>,
        metadata: list<metadata-column>,
    }

    variant map-key {
        boolean(bool),
        signed64(s64),
        unsigned64(u64),
        text(string),
        bytes(list<u8>),
    }

    variant map-value {
        boolean(bool),
        signed64(s64),
        unsigned64(u64),
        float64(f64),
        text(string),
        bytes(list<u8>),
    }

    variant map-error {
        unavailable,
        type-mismatch,
        key-too-large,
        value-too-large,
        call-limit,
        byte-limit,
    }

    record map-upsert {
        handle: map-handle,
        key: map-key,
        value: map-value,
        ttl-ms: option<u64>,
    }

    record map-add-i64 {
        handle: map-handle,
        key: map-key,
        delta: s64,
        ttl-ms: option<u64>,
    }

    record map-add-u64 {
        handle: map-handle,
        key: map-key,
        delta: u64,
        ttl-ms: option<u64>,
    }

    record map-delete {
        handle: map-handle,
        key: map-key,
    }

    variant map-mutation {
        upsert(map-upsert),
        add-i64(map-add-i64),
        add-u64(map-add-u64),
        delete(map-delete),
    }

    record request-context {
        logical-request-id: logical-request-id,
        generation-id: option<u64>,
        fields: record-batch,
    }

    enum admission-decision {
        accept,
        defer,
        reject,
    }

    enum placement-cause {
        generation-arrival,
        stage-transition,
        continuation,
    }

    enum schedule-cause {
        enqueue,
        service-step,
    }

    enum eviction-cause {
        allocation-deficit,
        memory-watermark,
    }

    record admission-input {
        links: link-set,
        request: request-context,
    }

    record admission-output {
        decision: admission-decision,
        mutations: list<map-mutation>,
    }

    record placement-input {
        links: link-set,
        cause: placement-cause,
        request: request-context,
        placement-count: u32,
        fields: record-batch,
    }

    record dense-output {
        scores: list<f64>,
        mutations: list<map-mutation>,
    }

    record service-candidate {
        logical-request-id: logical-request-id,
        generation-id: u64,
        max-token-budget: u32,
    }

    record service-capacity {
        max-selected: u32,
        max-total-tokens: u32,
        max-token-budget: u32,
    }

    record schedule-input {
        links: link-set,
        cause: schedule-cause,
        runnable: list<service-candidate>,
        fields: record-batch,
        capacity: service-capacity,
    }

    record service-decision {
        score: f64,
        token-budget: option<u32>,
    }

    record schedule-output {
        decisions: list<service-decision>,
        mutations: list<map-mutation>,
    }

    record resident-unit {
        size-bytes: u64,
        logical-request-id: option<logical-request-id>,
        generation-id: option<u64>,
    }

    record eviction-input {
        links: link-set,
        cause: eviction-cause,
        bytes-needed: u64,
        resident: list<resident-unit>,
        fields: record-batch,
    }

    record feedback-input {
        links: link-set,
        delivery-id: delivery-id,
        events: list<event-handle>,
        subjects: list<feedback-subject>,
        records: record-batch,
    }

    enum terminal-outcome {
        completed,
        cancelled,
        failed,
    }

    record feedback-subject {
        logical-request-id: logical-request-id,
        generation-id: option<u64>,
        terminal-outcome: option<terminal-outcome>,
    }

    record feedback-output {
        mutations: list<map-mutation>,
    }

    variant policy-error {
        fallback-required,
    }

    record telemetry-record {
        name: string,
        value: f64,
    }

    variant telemetry-error {
        record-limit,
        byte-limit,
        invalid-record,
    }
}
