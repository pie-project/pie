package pie:inferlet@0.2.0;

world inferlet {
    import types;
    import model;
    import tokenizer;
    import working-set;
    import forward;
    import grammar;
    import chat;
    import tools;
    import reasoning;
    import media;
    import speech;
    import messaging;
    import session;
    import system;

    // Standard wasi 0.3 surfaces (vendored from the wasmtime 46 p3 tree the
    // host implements). Outbound HTTP is wasi:http/client.send (NOT handler,
    // which is the incoming-server side); timing is native async
    // monotonic-clock.wait-for; snapshot I/O is wasi:filesystem@0.3.
    import wasi:http/client@0.3.0;
    import wasi:clocks/monotonic-clock@0.3.0;
    import wasi:filesystem/types@0.3.0;
    import wasi:filesystem/preopens@0.3.0;

    export run;
}
