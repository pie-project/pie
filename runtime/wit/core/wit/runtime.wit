interface runtime {

    use types.{blob, error};
    use wasi:io/poll@0.2.4.{pollable};

    // Returns the runtime version string
    version: func() -> string;

    // Returns a unique identifier for the running instance
    instance-id: func() -> string;

    // Returns the username of the user who invoked the inferlet
    username: func() -> string;

    // Get a list of all available model names
    models: func() -> list<string>;

    // Minimum per-request max-output-token ceiling across registered
    // models; 0 if no model is registered. Per model: configured
    // scheduler default_token_limit capped by raw engine KV capacity
    // when set, otherwise raw engine KV capacity.
    max-output-tokens: func() -> u32;

    // Store or overwrite engine-lifetime inferlet metadata under a namespace.
    metadata-put: func(namespace: string, key: string, value: blob) -> result<_, error>;

    // Retrieve engine-lifetime inferlet metadata from a namespace.
    metadata-get: func(namespace: string, key: string) -> result<option<blob>, error>;

    // Delete engine-lifetime inferlet metadata from a namespace.
    metadata-delete: func(namespace: string, key: string) -> result<bool, error>;

    // Launches another inferlet by `name@version`. Returns a `child` handle
    // on success. The child inherits the caller's username but is detached
    // from the caller's client session and MCP relay.
    //
    // Lifecycle:
    //   - Dropping the handle DETACHES — the child keeps running, its result
    //     is discarded.
    //   - `cancel()` hard-kills the child.
    //   - `pollable()` + `get()` retrieve the child's return value.
    launch: func(program: string, input: string) -> result<child, error>;

    // Handle to a launched child inferlet.
    resource child {
        // Pollable that fires when the child has produced a return value
        // (Ok, Err, or cancelled).
        pollable: func() -> pollable;

        // Outcome once the pollable is ready. Returns `none` if the child
        // has not finished yet. After cancellation, returns `some(err(...))`.
        get: func() -> option<result<string, error>>;

        // Process id (UUID) of the child, for logs / external bookkeeping.
        pid: func() -> string;

        // Hard-kill the child if still running. Idempotent — calling cancel
        // on an already-finished child is a no-op.
        cancel: func();
    }

}
