{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pie-project.org/schema/plex/0.6/actions/action-feedback.schema.json",
  "title": "PLEX v0.6 standard action feedback facts",
  "type": "object",
  "additionalProperties": false,
  "required": ["opportunity_id", "method", "idempotency_key", "status"],
  "properties": {
    "opportunity_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "method": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9._-]*@[1-9][0-9]*$"
    },
    "idempotency_key": {"type": "string", "minLength": 1, "maxLength": 128},
    "status": {
      "enum": [
        "succeeded",
        "failed",
        "already-terminal",
        "expired",
        "unsupported"
      ]
    },
    "details": {"$ref": "../document.schema.json"}
  }
}
