{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pie-project.org/schema/plex/0.6/manifest.schema.json",
  "title": "PLEX v0.6 package manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "package_name",
    "package_version",
    "implements",
    "requires",
    "optional",
    "schemas",
    "limits"
  ],
  "properties": {
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["major", "minor"],
      "properties": {
        "major": {"const": 0},
        "minor": {"const": 6}
      }
    },
    "package_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$"
    },
    "package_version": {
      "type": "string",
      "maxLength": 32,
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "implements": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["admit", "route", "schedule", "cache", "feedback"]
      }
    },
    "requires": {
      "$ref": "#/$defs/mechanic-list"
    },
    "optional": {
      "$ref": "#/$defs/mechanic-list"
    },
    "schemas": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "id", "required"],
        "properties": {
          "kind": {
            "enum": ["fact", "action-input", "action-feedback"]
          },
          "id": {
            "$ref": "#/$defs/versioned-name"
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "memory_bytes",
        "deadline_ms",
        "input_bytes",
        "output_bytes",
        "host_calls",
        "host_call_bytes"
      ],
      "properties": {
        "memory_bytes": {"type": "integer", "minimum": 1},
        "deadline_ms": {"type": "integer", "minimum": 1},
        "input_bytes": {"type": "integer", "minimum": 1},
        "output_bytes": {"type": "integer", "minimum": 1},
        "host_calls": {"type": "integer", "minimum": 1, "maximum": 4294967295},
        "host_call_bytes": {"type": "integer", "minimum": 1}
      }
    }
  },
  "$defs": {
    "versioned-name": {
      "type": "string",
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9._-]*@[1-9][0-9]*$"
    },
    "mechanic-list": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/versioned-name"
      }
    }
  }
}
