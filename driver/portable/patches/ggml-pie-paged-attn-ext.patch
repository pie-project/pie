+// ggml_paged_attn_ext (pie patch)
+//
+// Op-params layout (24 bytes; fits in GGML_MAX_OP_PARAMS = 64):
+//   [0] f32  scale
+//   [1] f32  softcap        (0.0 disables tanh-softcap)
+//   [2] i32  page_size
+//   [3] i32  head_dim       (per-layer; Gemma 4 sliding vs full differ)
+//   [4] i32  n_kv_heads     (per-layer)
+//   [5] i32  sliding_window (-1 = disabled, full causal)
+//
+// src layout:
+//   src[0] = q                [head_dim, n_q_tokens, n_q_heads, n_req]
+//   src[1] = k_pool           [head_dim * n_kv_heads, total_pages*page_size]
+//   src[2] = v_pool           (same shape as k_pool)
+//   src[3] = page_indices     [total_pages_in_batch] I32
+//   src[4] = page_indptr      [n_req + 1] I32
+//   src[5] = last_page_lens   [n_req] I32
+struct ggml_tensor * ggml_paged_attn_ext(
+        struct ggml_context * ctx,
+        struct ggml_tensor  * q,
+        struct ggml_tensor  * k_pool,
+        struct ggml_tensor  * v_pool,
+        struct ggml_tensor  * page_indices,
+        struct ggml_tensor  * page_indptr,
+        struct ggml_tensor  * last_page_lens,
+        int                   page_size,
+        int                   head_dim,
+        int                   n_kv_heads,
+        int                   sliding_window,
+        float                 scale,
+        float                 softcap) {
+    GGML_ASSERT(k_pool->ne[0] == (int64_t) head_dim * n_kv_heads);
+    GGML_ASSERT(v_pool->ne[0] == (int64_t) head_dim * n_kv_heads);
+    GGML_ASSERT(page_indices->type   == GGML_TYPE_I32);
+    GGML_ASSERT(page_indptr->type    == GGML_TYPE_I32);
+    GGML_ASSERT(last_page_lens->type == GGML_TYPE_I32);
+    GGML_ASSERT(page_indptr->ne[0]    == q->ne[3] + 1);
+    GGML_ASSERT(last_page_lens->ne[0] == q->ne[3]);
+
+    // Output shape mirrors flash_attn_ext: [v_head_dim, n_q_heads, n_q_tokens, n_req].
+    // Q is laid out as [head_dim, n_q_tokens, n_q_heads, n_req] so we permute
+    // ne[1] and ne[2] to put n_q_heads first.
+    int64_t ne[4] = { q->ne[0], q->ne[2], q->ne[1], q->ne[3] };
+    struct ggml_tensor * result = ggml_new_tensor(ctx, q->type, 4, ne);
+
+    int32_t params_i32[6];
+    memcpy(&params_i32[0], &scale,   sizeof(float));
+    memcpy(&params_i32[1], &softcap, sizeof(float));
+    params_i32[2] = page_size;
+    params_i32[3] = head_dim;
+    params_i32[4] = n_kv_heads;
+    params_i32[5] = sliding_window;
+    ggml_set_op_params(result, params_i32, sizeof(params_i32));
+
+    result->op     = GGML_OP_PAGED_ATTN_EXT;
+    result->src[0] = q;
+    result->src[1] = k_pool;
+    result->src[2] = v_pool;
+    result->src[3] = page_indices;
+    result->src[4] = page_indptr;
+    result->src[5] = last_page_lens;
+
+    return result;
+}
